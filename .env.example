# ── Required ─────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Retail Environment Server ────────────────────────────────────────
ENV_BASE_URL=http://127.0.0.1:8000

# ── OpenAI-compatible API (hackathon requirement) ────────────────────
API_BASE_URL=https://router.huggingface.co/v1
MODEL_NAME=meta-llama/Llama-3.1-8B-Instruct
HF_TOKEN=hf_your_token_here

# ── RAG Pipeline ─────────────────────────────────────────────────────
FAISS_INDEX_PATH=./vectorstore

# ── Optional: Use local Ollama for the router instead of Groq ────────
USE_OLLAMA_ROUTER=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_ROUTER_MODEL=qwen2.5-coder:7b
